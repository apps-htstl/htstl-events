# ==============================================================================
# HTSL Events — Environment Variables Template (.env.example)
# This file is committed to git. Do NOT add real secrets here.
# ==============================================================================

# ─── FIREBASE CONFIGURATION ───────────────────────────────────────────────────
EXPO_PUBLIC_FIREBASE_API_KEY="your_api_key_here"
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN="your_project_id.firebaseapp.com"
EXPO_PUBLIC_FIREBASE_PROJECT_ID="your_project_id"
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET="your_project_id.appspot.com"
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your_sender_id_here"
EXPO_PUBLIC_FIREBASE_APP_ID="your_app_id_here"

# ─── APPLICATION CONFIGURATION ────────────────────────────────────────────────
EXPO_PUBLIC_ORG_ID="hindu-temple-stl"
EXPO_PUBLIC_ORG_NAME="Hindu Temple of St. Louis"
EXPO_PUBLIC_MAX_PARTY_SIZE=20
EXPO_PUBLIC_TICKET_BASE_URL="https://your_project_id.web.app/ticket"
# Default password set for all provisioned staff accounts (keep secret — do not commit real value)
EXPO_PUBLIC_DEFAULT_USER_PASSWORD=

# ─── DELIVERY CHANNELS ────────────────────────────────────────────────────────
EXPO_PUBLIC_ENABLE_SMS=false

# ─── LOCAL SECRETS (Do NOT commit real values to .env.local) ──────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
QR_ENCRYPTION_SECRET=
